// Exemplo de arquivo .env para configuração do banco de dados e outras variáveis de ambiente

DB_USER=seu_usuario
DB_PASS=sua_senha
DB_NAME=api_db
DB_HOST=localhost
DB_PORT= sua_porta_aqui (ex: 3000)
DB_DIALECT= seu_dialect_aqui (ex: postgres, mysql, etc.)
JWT_SECRET=sua_chave_secreta_aqui
EMAIL_USER=seu_email_aqui
EMAIL_PASS=sua_senha_de_app_email_aqui

//Não se esqueça de colocar o .env no .gitignore para evitar que informações sensíveis sejam expostas no repositório!